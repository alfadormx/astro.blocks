---
import Layout from '../_layouts/Layout.astro';
import TabPanelBlock from '~/components/blocks/primitives/TabPanel.astro';

const metadata = { title: { default: 'Tab Panel' } };
---

<Layout
  metadata={metadata}
  headline={{
    tagline: 'Primitive',
    title: 'Tab Panel',
    subtitle: 'Panel wrapper for use within the Tabs composite block.',
  }}
>
  <h3>Default</h3>
  <TabPanelBlock>
    <p>Panel content goes here.</p>
  </TabPanelBlock>

  <h3>With custom class</h3>
  <TabPanelBlock class="p-8 bg-surface rounded-lg">
    <p>Panel with custom padding and background.</p>
  </TabPanelBlock>
</Layout>
