---
import type { TabsProps } from '~/types/tabs.types';
import type { ButtonProps } from '~/types/button.types';
import type { ContainerProps } from '~/types/container.types';
import Button from '~/components/blocks/primitives/Button.astro';
import Container from '~/components/blocks/layout/Container.astro';
import { mergeConfigs } from '~/utils/mergeConfigs';
import { cn } from '~/utils/styles';

type Props = TabsProps;

const {
  items,
  defaultTabConfig,
  activeTabConfig,
  orientation = 'horizontal',
  container,
} = Astro.props;

const internalTabDefaults: Partial<ButtonProps> = {
  variant: 'ghost',
  intent: 'neutral',
  size: 'md',
};

const defaultContainer: Partial<ContainerProps> = {};
const mergedContainer = mergeConfigs({}, defaultContainer, container || {});

const tabsWrapperClass = cn(
  orientation === 'vertical' ? 'grid grid-cols-[auto_1fr]' : 'flex flex-col'
);

const tabListClass = cn(orientation === 'vertical' ? 'flex flex-col' : 'flex flex-row');
---

<Container {...mergedContainer}>
  <div class={tabsWrapperClass} data-tabs-root>
    <div role="tablist" class={tabListClass}>
      {
        items.map((item, n) => {
          const inactiveMerge = mergeConfigs({}, internalTabDefaults, defaultTabConfig || {}, item);
          const activeMerge = mergeConfigs(
            {},
            internalTabDefaults,
            defaultTabConfig || {},
            activeTabConfig || {},
            item
          );
          return (
            <span data-tab-index={String(n)}>
              <span data-tab-button="inactive">
                <Button {...inactiveMerge} />
              </span>
              <span data-tab-button="active" hidden>
                <Button {...activeMerge} />
              </span>
            </span>
          );
        })
      }
    </div>
    <div>
      {
        items.length > 0 && (
          <div data-tab-panel="0">
            <slot name="panel-0" />
          </div>
        )
      }
      {
        items.length > 1 && (
          <div data-tab-panel="1" hidden>
            <slot name="panel-1" />
          </div>
        )
      }
      {
        items.length > 2 && (
          <div data-tab-panel="2" hidden>
            <slot name="panel-2" />
          </div>
        )
      }
      {
        items.length > 3 && (
          <div data-tab-panel="3" hidden>
            <slot name="panel-3" />
          </div>
        )
      }
      {
        items.length > 4 && (
          <div data-tab-panel="4" hidden>
            <slot name="panel-4" />
          </div>
        )
      }
      {
        items.length > 5 && (
          <div data-tab-panel="5" hidden>
            <slot name="panel-5" />
          </div>
        )
      }
      {
        items.length > 6 && (
          <div data-tab-panel="6" hidden>
            <slot name="panel-6" />
          </div>
        )
      }
      {
        items.length > 7 && (
          <div data-tab-panel="7" hidden>
            <slot name="panel-7" />
          </div>
        )
      }
      {
        items.length > 8 && (
          <div data-tab-panel="8" hidden>
            <slot name="panel-8" />
          </div>
        )
      }
      {
        items.length > 9 && (
          <div data-tab-panel="9" hidden>
            <slot name="panel-9" />
          </div>
        )
      }
    </div>
  </div>
</Container>

<script>
  type TabsInstance = { activeIndex: number; idPrefix: string };

  const tabsMap = new WeakMap<HTMLElement, TabsInstance>();
  let tabsCounter = 0;

  function setActiveTab(root: HTMLElement, instance: TabsInstance, newIndex: number): void {
    instance.activeIndex = newIndex;

    const tabSpans = root.querySelectorAll<HTMLElement>('[data-tab-index]');
    const panels = root.querySelectorAll<HTMLElement>('[data-tab-panel]');

    tabSpans.forEach((span, i) => {
      const inactiveWrap = span.querySelector<HTMLElement>('[data-tab-button="inactive"]');
      const activeWrap = span.querySelector<HTMLElement>('[data-tab-button="active"]');
      const isActive = i === newIndex;

      if (inactiveWrap) inactiveWrap.hidden = isActive;
      if (activeWrap) activeWrap.hidden = !isActive;

      const inactiveBtn = inactiveWrap?.querySelector<HTMLElement>('[role="tab"]');
      const activeBtn = activeWrap?.querySelector<HTMLElement>('[role="tab"]');
      if (inactiveBtn) inactiveBtn.setAttribute('aria-selected', 'false');
      if (activeBtn) activeBtn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    panels.forEach((panel, i) => {
      panel.hidden = i !== newIndex;
      panel.setAttribute('aria-hidden', i !== newIndex ? 'true' : 'false');
    });
  }

  function initTabs(): void {
    document.querySelectorAll<HTMLElement>('[data-tabs-root]').forEach((root) => {
      if (tabsMap.has(root)) return;

      const idPrefix = `tabs-${tabsCounter++}`;
      const instance: TabsInstance = { activeIndex: 0, idPrefix };
      tabsMap.set(root, instance);

      const tabSpans = root.querySelectorAll<HTMLElement>('[data-tab-index]');
      const panels = root.querySelectorAll<HTMLElement>('[data-tab-panel]');

      tabSpans.forEach((span, i) => {
        const tabId = `${idPrefix}-tab-${i}`;
        const panelId = `${idPrefix}-panel-${i}`;

        span.querySelectorAll<HTMLElement>('button, a').forEach((btn, btnIdx) => {
          btn.setAttribute('role', 'tab');
          btn.id = `${tabId}-${btnIdx === 0 ? 'inactive' : 'active'}`;
          btn.setAttribute('aria-controls', panelId);
          btn.setAttribute('aria-selected', 'false');
          btn.setAttribute('tabindex', i === 0 ? '0' : '-1');
        });
      });

      panels.forEach((panel, i) => {
        panel.id = `${idPrefix}-panel-${i}`;
        panel.setAttribute('role', 'tabpanel');
        panel.setAttribute('aria-labelledby', `${idPrefix}-tab-${i}-active`);
      });

      setActiveTab(root, instance, 0);

      root.addEventListener('click', (e: Event) => {
        const span = (e.target as HTMLElement).closest<HTMLElement>('[data-tab-index]');
        if (!span) return;
        const idx = parseInt(span.dataset.tabIndex!, 10);
        const inst = tabsMap.get(root);
        if (!inst || isNaN(idx)) return;
        setActiveTab(root, inst, idx);
      });
    });
  }

  document.addEventListener('astro:after-swap', initTabs);
  initTabs();
</script>
