---
import type { ContainerProps } from '~/types/container.types';
import Background from '~/components/blocks/primitives/Background.astro';
import { cn } from '~/utils/styles';

type Props = ContainerProps;

// Configuration: Air/spacing settings
const airSettings = {
  none: '',
  tight: 'px-4 py-8 md:px-6 md:py-12 lg:px-8 lg:py-16',
  normal: 'px-4 py-12 md:px-8 md:py-16 lg:px-12 lg:py-20',
  loose: 'px-6 py-16 md:px-12 md:py-24 lg:px-16 lg:py-32',
};

const {
  htmlTag: ContainerTag = 'section',
  containerWidthType = 'full',
  class: className = '',
  background,
  spacing,
  border,
  layout,
  items = [],
  width: widthClass = '',
  minHeight: minHeightClass = '',
  equalHeight = false,
  overflow,
  content: {
    widthType: contentWidthType = 'boxed',
    boxWidth: contentBoxWidth = 'max-w-[var(--container-max-width)]',
    air: containerAir = 'normal',
    class: contentClassName = '',
    spacing: contentSpacing,
    border: contentBorder,
  } = {},
} = Astro.props;

const layoutType = layout?.type ?? '';
const layoutClass = layout?.class ?? '';

const hasBackground = !!background || Astro.slots.has('background');

const containerClass = cn(
  hasBackground && 'relative',
  containerWidthType === 'boxed' && 'mx-auto max-w-[var(--container-max-width)]',
  containerWidthType === 'custom' && 'mx-auto',
  widthClass,
  minHeightClass,
  overflow && `overflow-${overflow}`,
  cn(airSettings[containerAir], spacing?.padding),
  spacing?.margin,
  spacing?.gap,
  border?.width,
  border?.color,
  border?.radius,
  className
);

const containerStyle = hasBackground ? 'position:relative;' : '';

const contentClass = cn(
  'w-full h-full relative z-1',
  layoutType,
  layoutClass,
  containerWidthType === 'full' &&
    contentWidthType === 'boxed' && [contentBoxWidth, 'mx-auto', minHeightClass],
  containerWidthType === 'full' && contentWidthType === 'full' && 'w-full',
  contentSpacing?.padding,
  contentSpacing?.margin,
  contentSpacing?.gap,
  contentBorder?.width,
  contentBorder?.color,
  contentBorder?.radius,
  contentClassName,
  equalHeight && 'items-stretch'
);
---

<ContainerTag class={containerClass} style={containerStyle}>
  {
    Astro.slots.background ? (
      <slot name="background" />
    ) : background ? (
      <Background
        {...background}
      />
    ) : null
  }
  <div class={contentClass}>
    {
      items && items.length > 0 ? (
        items.map((item) => <div class={item.class} id={item.id} set:html={item.content} />)
      ) : (
        <slot />
      )
    }
  </div>
</ContainerTag>
