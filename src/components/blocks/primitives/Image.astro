---
import type { HTMLAttributes } from 'astro/types';
import type { ImageProps } from '~/types/image.types';
import { findImage } from '~/utils/images';
import {
  getImagesOptimized,
  astroAssetsOptimizer,
  unpicOptimizer,
  isUnpicCompatible,
} from '~/utils/images-optimization';

type ImageType = {
  src: string;
  attributes: HTMLAttributes<'img'>;
};

type Props = ImageProps;

const {
  src,
  alt,
  width: rawWidth,
  height: rawHeight,
  loading: rawLoading,
  decoding: rawDecoding,
  align,
  layout,
  ...rest
} = Astro.props;

if (alt === undefined || alt === null) {
  throw new Error('Image component requires an alt attribute for accessibility');
}

const width = typeof rawWidth === 'string' ? parseInt(rawWidth) : rawWidth;
const height = typeof rawHeight === 'string' ? parseInt(rawHeight) : rawHeight;
const loading = rawLoading ?? 'lazy';
const decoding = rawDecoding ?? 'async';

// Build alignment class
const alignClass =
  align === 'center'
    ? 'flex justify-center'
    : align === 'right'
      ? 'flex justify-end'
      : align === 'left'
        ? 'flex justify-start'
        : '';

const wrapperClass =
  layout === 'contained' || layout === 'cover' ? `${alignClass} w-full h-full` : alignClass;

const imageProps: ImageProps = { ...rest, src, alt, width, height, loading, decoding, align, layout };

const _image = await findImage(src);

let image: ImageType | undefined = undefined;

if (
  typeof _image === 'string' &&
  (_image.startsWith('http://') || _image.startsWith('https://')) &&
  isUnpicCompatible(_image)
) {
  image = await getImagesOptimized(_image, imageProps, unpicOptimizer);
} else if (_image) {
  image = await getImagesOptimized(_image, imageProps, astroAssetsOptimizer);
}
---

{
  !image ? (
    <Fragment />
  ) : (
    <div class={wrapperClass}>
      <img src={image.src} referrerpolicy="no-referrer" {...image.attributes} />
    </div>
  )
}
